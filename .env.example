# Discord Configuration
# Bot token from Discord Developer Portal (https://discord.com/developers/applications)
DISCORD_TOKEN=your_bot_token_here

# Application client ID from Discord Developer Portal
DISCORD_CLIENT_ID=your_client_id_here

# Bot Operating Mode
# Only "microservice" is supported (routes through the Python cognition service
# /respond — the single LLM call path, ADR-003/010). The JS "direct" mode was a
# duplicate pipeline and has been removed. BOT_MODE is retained as a cosmetic
# status field.
BOT_MODE=microservice

# AI Adapter Configuration
# Anthropic Claude API key (required if PRIMARY_ADAPTER=claude)
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_key_here

# MiniMax API key (required if PRIMARY_ADAPTER=minimax)
MINIMAX_API_KEY=your_minimax_key_here

# MiniMax group ID (required if using MiniMax adapter)
MINIMAX_GROUP_ID=your_group_id_here

# Primary AI Adapter Selection
# Options: "claude", "minimax"
# Default: claude
PRIMARY_ADAPTER=claude

# Weather Integration (Optional)
# OpenWeather API key for dynamic mood modifiers based on weather
# Get from: https://openweathermap.org/api
# If omitted, weather mood modifiers are disabled
OPENWEATHER_API_KEY=your_weather_key_here

# City name for weather queries (used with OpenWeather integration)
# Default: London
PACKY_LOCATION=London

# Cognition Microservice Configuration
# Port for the Python FastAPI cognition service
# Default: 8765
COGNITION_PORT=8765

# Bind host for cognition microservice (security: use 127.0.0.1 in production)
# Default: 127.0.0.1
COGNITION_BIND_HOST=127.0.0.1

# Bearer token for microservice auth (required in production)
# If set, all /respond calls must include: Authorization: Bearer <token>
# If empty, auth is disabled (dev mode only)
PACKY_API_SECRET=

# Input length cap before LLM dispatch
# Prevents expensive completions from very long messages
# Default: 1500
MAX_INPUT_CHARS=1500

# Full URL override for cognition service
# If not set, defaults to http://localhost:{COGNITION_PORT}
# Use this to specify a remote microservice URL
COGNITION_URL=http://localhost:8765

# Logging Configuration
# Log level for console output
# Options: debug, info, warn, error
# Default: info
LOG_LEVEL=info

# Redis Configuration (Optional - for rate limiting in PM2 cluster mode)
# If set, rate limiter uses Redis instead of in-memory Map
# Required for multi-process deployments (PM2 cluster mode)
# If not set, falls back to in-memory rate limiting (single process only)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_KEY_PREFIX=packy:ratelimit:

# SQLite State Store (Optional)
# Path to the SQLite database for guild/user/chaos state persistence.
# Defaults to data/packy_state.db if not set.
# On first boot, JSON files are migrated to SQLite automatically
# (original JSON files are kept as backup, never deleted).
PACKY_DB_PATH=

# Sentry (Optional)
# If set, errors are also reported to Sentry via @sentry/node (lazy-init).
# If unset, metrics fall back to a local ring buffer flushed to SQLite every 60s.
SENTRY_DSN=

# Compose Model (Optional)
# Model used for cheap-LLM emergency fallback when primary LLM call fails.
# If set, the emergency composer first calls this model before falling back
# to random.choice templates. Default: claude-haiku-4-5-20251001
PACKY_COMPOSE_MODEL=

# CORS Configuration (Optional)
# Comma-separated list of allowed origins for the cognition endpoint.
# If not set, CORS is disabled (same-origin only — most secure).
# Example: PACKY_CORS_ORIGINS=https://packy.example.com,https://admin.example.com
PACKY_CORS_ORIGINS=
