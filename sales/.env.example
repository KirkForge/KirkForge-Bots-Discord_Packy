# Sales service environment.
# Copy to .env, fill in the values, then `set -a; source .env; set +a`
# before running `python -m sales`.

# --- Bind (loopback by default; set to 0.0.0.0 in production) -----------
SALES_BIND=127.0.0.1
SALES_PORT=8766

# --- Stripe -------------------------------------------------------------
# Get these from https://dashboard.stripe.com/apikeys
# Use test keys (sk_test_..., whsec_test_...) for development, live
# keys (sk_live_..., whsec_live_...) in production.
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me_from_stripe_webhook_endpoint

# Stripe Price IDs for each tier. Create the products + prices in
# https://dashboard.stripe.com/products and paste the price IDs here.
STRIPE_PRICE_INDIE=price_indie_replace_me
STRIPE_PRICE_PRO=price_pro_replace_me
STRIPE_PRICE_ENTERPRISE=price_ent_replace_me

# Where Stripe sends the customer after a successful payment / cancel.
# Must be HTTPS in production.
SALES_SUCCESS_URL=https://kirkforge.com/packy/success.html
SALES_CANCEL_URL=https://kirkforge.com/packy/pricing.html

# --- SMTP (for delivering license.json to the buyer) --------------------
# We recommend Postmark or SES for transactional email. Gmail works
# with an "app password" if you have 2FA on. The sales service uses
# STARTTLS by default.
SMTP_HOST=smtp.postmarkapp.com
SMTP_PORT=587
SMTP_USER=postmark-server-token-here
SMTP_PASSWORD=postmark-server-token-here
SMTP_FROM=licenses-packy@kirkforge.com
SMTP_USE_TLS=true

# --- License signing ----------------------------------------------------
# Path to the Ed25519 private key. Generate with:
#     python -m tools.keygen init
# then move the file to a secure location and chmod 600.
# The key MUST be backed up. Loss of this key makes every issued
# license unverifiable.
LICENSE_PRIVATE_KEY_PATH=/var/lib/sales-packy/private_key.pem

# Product metadata embedded in the license. Bump product_version
# when the product schema changes.
LICENSE_PRODUCT_ID=gargoyle-packy
LICENSE_PRODUCT_VERSION=2.0.0

# --- Database -----------------------------------------------------------
# SQLite is fine for thousands of customers. For tens of thousands,
# switch to Postgres by replacing sales/db.py's _connect().
SALES_DB_PATH=/var/lib/sales-packy/sales.db
